POSTGRES_DB=hez_tool
POSTGRES_USER=hez
POSTGRES_PASSWORD=hez_dev_password
DATABASE_URL=postgresql+psycopg://hez:hez_dev_password@postgres:5432/hez_tool
LLM_PROVIDER=both
GENERATOR_PARALLELISM=3
GENERATOR_SUBAGENT_LIMIT=3
GENERATOR_TASK_TIMEOUT_SECONDS=1800
CODEX_PROFILE=hez-generator
CODEX_MODEL=gpt-5.4
OPENAI_API_KEY=
CLAUDE_MODEL=
ANTHROPIC_API_KEY=
GLINER_MODEL_NAME=urchade/gliner_multi_pii-v1
PRIVACY_MAPPING_TTL_HOURS=24
JWT_SECRET=change-me-in-production
JWT_ACCESS_TOKEN_MINUTES=480
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin
PUBLIC_BASE_DOMAIN=hez.tech-artist.de
STORAGE_ROOT=/storage
REFERENCE_SCHEMA_PATH=/reference_schema
# Sprachnotiz-Transkription (Phase 13.2)
# WHISPER_PROVIDER:
#   openai       -> OpenAI Whisper, Codex CLI als automatischer Fallback (Empfohlen)
#   openai_only  -> Nur OpenAI Whisper, kein Fallback
#   codex        -> Nur Codex CLI
#   local        -> faster-whisper lokal (kostenlos, langsamer auf CPU)
#   chain        -> Custom-Kette via WHISPER_CHAIN, z.B. "openai,local,codex"
#   off          -> deaktiviert
WHISPER_PROVIDER=openai
WHISPER_CHAIN=
WHISPER_MODEL=small
# Optional: dediziertes Codex-Modell fuer Audio (falls anders als CODEX_MODEL)
CODEX_AUDIO_MODEL=

# Web Push (Phase 14.4) - generieren mit: python -m scripts.generate_vapid_keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@hez.tech-artist.de

# Audit/Retention (Phase 16)
DEFAULT_RETENTION_DAYS=0
